# Environment Selection
# Switch between 'prod' or 'test' to use different databases
ENV=test

# Production Database
# Get these from your PRODUCTION Supabase project settings
SUPABASE_URL_PROD=https://your-prod-project.supabase.co
SUPABASE_ANON_KEY_PROD=your_prod_anon_key_here

# Test Database
# Get these from your TEST Supabase project settings
SUPABASE_URL_TEST=https://your-test-project.supabase.co
SUPABASE_ANON_KEY_TEST=your_test_anon_key_here

# Legacy support (optional - for backwards compatibility)
SUPABASE_URL=https://your-prod-project.supabase.co
SUPABASE_ANON_KEY=your_prod_anon_key_here

# ============================================
# HOW TO USE:
# ============================================
# 1. Copy this file to .env
# 2. Create TWO Supabase projects (Production and Test)
# 3. Fill in the credentials above
# 4. Change ENV to 'prod' or 'test' to switch databases
# 5. Run: flutter clean && flutter pub get && flutter run
#
# When you run the app, check the console:
# - "🚀 Using PRODUCTION database" = prod mode
# - "📊 Using TEST database" = test mode
